{
  "name": "gymproject-desktop",
  "productName": "GymProject Desktop",
  "private": true,
  "version": "1.0.9",
  "description": "GymProject Desktop App con scanner QR globale e AI people counter",
  "author": "GymProject Team",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.30.0",
    "@date-io/date-fns": "^3.2.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.2.0",
    "@mui/lab": "^7.0.0-beta.11",
    "@mui/material": "^7.2.0",
    "@mui/x-date-pickers": "^7.28.3",
    "@reduxjs/toolkit": "^2.6.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^4.4.1",
    "@yudiel/react-qr-scanner": "^2.5.1",
    "axios": "^1.8.4",
    "date-fns": "^2.30.0",
    "dotenv": "^16.3.1",
    "electron-is-dev": "^2.0.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "i18next": "^24.2.3",
    "node-hid": "^3.3.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.4.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.5.0",
    "redux-persist": "^6.0.0",
    "uiohook-napi": "^1.5.3",
    "winston": "^3.11.0"
  },
  "build": {
    "appId": "com.gymproject.desktop",
    "productName": "GymProject Desktop",
    "publish": [
      {
        "provider": "github",
        "owner": "Frenklyn96",
        "repo": "palestra-frontend"
      }
    ],
    "directories": {
      "buildResources": "electron/assets",
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "AI/ai-service",
        "to": "ai-service",
        "filter": [
          "**/*",
          "!**/__pycache__/**/*",
          "!**/build/**/*",
          "!**/package_output/**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico",
      "extraResources": [
        {
          "from": "python-embed-win",
          "to": "python",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
